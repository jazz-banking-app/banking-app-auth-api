# HTTP
HTTP_HOST=localhost
HTTP_PORT=8081
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=auth_user
DB_PASSWORD=1707
DB_NAME=auth_db
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=1202
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# URLs
API_BASE_URL=http://localhost:8081
FRONTEND_URL=http://localhost:3000
SWAGGER_URL=http://localhost:8081/swagger/doc.json

# Rate Limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=15m